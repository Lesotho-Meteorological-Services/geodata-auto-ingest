# Local GeoTIFF source produced by LMS or another upstream workflow
SRC_FILE=/data/lms/output/example_raster.tif

# Required GeoManager ISO UTC suffix for GeoTIFF ingest
ISO_TIMESTAMP=2026-04-01T00:00:00.000Z

# Base ingest file name without timestamp or extension
INGEST_STEM=lms-example-raster

# Optional boundary file for clipping before ingest. Leave empty to skip host-side clipping.
BOUNDARY=/data/chirps-manual/raw/lesotho_boundary_admin0.geojson

WORK_DIR=/data/geodata-auto-ingest/work/lms-geotiff-template
INGEST_DIR=/opt/climweb-docker/climweb/geomanager-data/lms-example-raster
LAYER_DIR_NAME=lms-example-raster
CONTAINER=climweb

# Logging
LOG_DIR=/var/log/geodata-auto-ingest
LOG_FILE=lms_geotiff_template.log
LOG_MAX_BYTES=5242880
LOG_BACKUP_COUNT=5
