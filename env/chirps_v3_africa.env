# Boundary file used by gdalwarp -cutline
BOUNDARY=/opt/geodata-auto-ingest/boundaries/lesotho_boundary_admin0.geojson

# Working directory for downloads and clipped rasters
WORK_DIR=/opt/geodata-auto-ingest/work/chirps-v3-africa

# Host directory that is mounted into GEOMANAGER_AUTO_INGEST_RASTER_DATA_DIR
INGEST_DIR=/home/csis/climweb/climweb/geomanager-data/chirps-dekadal-lesotho

# GeoManager custom directory name for the raster layer
LAYER_DIR_NAME=chirps-dekadal-lesotho

# Docker container name running Climweb
CONTAINER=climweb

# CHIRPS v3 Africa dekadal source
BASE_URL=https://data.chc.ucsb.edu/products/CHIRPS/v3.0/dekads/africa/tifs/
VERSION_PREFIX=chirps-v3.0

# Logging
LOG_DIR=/opt/geodata-auto-ingest/log
LOG_FILE=chirps_v3_africa.log
LOG_MAX_BYTES=5242880
LOG_BACKUP_COUNT=5
