# Use one of SRC_FILE or URL
SRC_FILE=/data/upstream/example.nc
URL=

# Base file name to use inside the GeoManager ingest directory, without extension
STAGED_NAME=example-forecast-timeseries

WORK_DIR=/data/geodata-auto-ingest/work/netcdf-template
INGEST_DIR=/opt/climweb-docker/climweb/geomanager-data/example-forecast-timeseries
LAYER_DIR_NAME=example-forecast-timeseries
CONTAINER=climweb

# Optional local validation. This should match the layer's "Data variable for netCDF data auto ingest" in GeoManager.
EXPECTED_VARIABLE=precip

# Let GeoManager perform clipping against configured admin boundaries during ingest.
CLIP_IN_GEOMANAGER=true

# Logging
LOG_DIR=/var/log/geodata-auto-ingest
LOG_FILE=netcdf_template.log
LOG_MAX_BYTES=5242880
LOG_BACKUP_COUNT=5
